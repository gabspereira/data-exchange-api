{
  "name": "demand-planning-pipeline",
  "description": "Demand Planning ELT pipeline: Bronze → Silver → Gold (demand_rpt). Runs daily at 06:00 UTC.",
  "schedule": {
    "quartz_cron_expression": "0 0 6 * * ?",
    "timezone_id": "America/Sao_Paulo",
    "pause_status": "UNPAUSED"
  },
  "max_concurrent_runs": 1,
  "email_notifications": {
    "on_failure": ["<your-email@example.com>"],
    "no_alert_for_skipped_runs": true
  },
  "tags": {
    "team": "data-engineering",
    "domain": "demand-planning",
    "layer": "pipeline"
  },
  "tasks": [
    {
      "task_key": "bronze_ingestion",
      "description": "Ingest anonymized SAP CSV exports into Delta Bronze tables with schema enforcement.",
      "notebook_task": {
        "notebook_path": "/Repos/<your-workspace>/data-exchange-api/notebooks/01_bronze_ingestion",
        "source": "WORKSPACE"
      },
      "job_cluster_key": "pipeline_cluster",
      "retry_on_timeout": true,
      "max_retries": 2,
      "min_retry_interval_millis": 60000,
      "timeout_seconds": 1800
    },
    {
      "task_key": "silver_transform",
      "description": "Clean, cast, and join Bronze tables into Silver. Runs DQ checks and logs results.",
      "depends_on": [
        { "task_key": "bronze_ingestion" }
      ],
      "notebook_task": {
        "notebook_path": "/Repos/<your-workspace>/data-exchange-api/notebooks/02_silver_transform",
        "source": "WORKSPACE"
      },
      "job_cluster_key": "pipeline_cluster",
      "retry_on_timeout": true,
      "max_retries": 2,
      "min_retry_interval_millis": 60000,
      "timeout_seconds": 3600
    },
    {
      "task_key": "gold_demand_rpt",
      "description": "Build gold.demand_rpt: enriched order lines with UOM conversion, pricing, org structure, and composite KEY.",
      "depends_on": [
        { "task_key": "silver_transform" }
      ],
      "notebook_task": {
        "notebook_path": "/Repos/<your-workspace>/data-exchange-api/notebooks/03_gold_demand_rpt",
        "source": "WORKSPACE",
        "base_parameters": {
          "plant_codes": "PLNT-01,PLNT-02,PLNT-03,PLNT-04,PLNT-05,PLNT-06",
          "order_types": "ORD-TYPE-A,ORD-TYPE-B,ORD-TYPE-C"
        }
      },
      "job_cluster_key": "pipeline_cluster",
      "retry_on_timeout": true,
      "max_retries": 1,
      "min_retry_interval_millis": 120000,
      "timeout_seconds": 3600
    }
  ],
  "job_clusters": [
    {
      "job_cluster_key": "pipeline_cluster",
      "new_cluster": {
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "num_workers": 2,
        "spark_conf": {
          "spark.databricks.delta.preview.enabled": "true",
          "spark.sql.adaptive.enabled": "true",
          "spark.sql.shuffle.partitions": "auto"
        },
        "azure_attributes": {
          "availability": "SPOT_WITH_FALLBACK_AZURE",
          "spot_bid_max_price": -1
        }
      }
    }
  ],
  "run_as": {
    "service_principal_name": "<your-service-principal>"
  }
}
